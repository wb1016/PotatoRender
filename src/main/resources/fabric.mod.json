{
    "schemaVersion": 1,
    "id": "potato-render",
    "version": "${version}",
    "name": "PotatoRender",
    "description": "a mod turns your renderer to potato to increase FPS. supports both OpenGL and Vulkan.",
    "authors": [
        "Blue_ON"
    ],
    "contact": {
        "sources": "https://github.com/wb1016/PotatoRender"
    },
    "license": "Apache-2.0",
    "icon": "assets/potatorender/potatorender.png",
    "environment": "client",
    "entrypoints": {
        "main": [
            "dev.blueon.potatorender.PotatoRender"
        ]
    },
    "mixins": [
        "potatorender.mixins.json"
    ],
    "depends": {
        "fabric-api": "*",
        "fabricloader": ">=${loader_version}",
        "minecraft": "*"
    },
    "custom": {
        "modmenu": {
            "links": {
                "modmenu.donate": "https://github.com/sponsors/wb1016",
                "modmenu.github_releases": "https://github.com/wb1016/PotatoRender/releases",
                "modmenu.modrinth": "https://modrinth.com/mod/potatorender"
            }
        }
    }
}
